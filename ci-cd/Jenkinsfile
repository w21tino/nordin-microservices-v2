pipeline {

    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'JDK-21'
    }

    environment {
        AWS_REGION     = "${env.AWS_REGION ?: 'us-east-1'}"
        AWS_ACCOUNT_ID = "${env.AWS_ACCOUNT_ID ?: ''}"
        IMAGE_TAG      = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'local'}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 90, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Compilar + Tests') {
            steps {
                echo "🔨 Compilando y ejecutando tests..."
                sh 'mvn clean verify -B'
            }
            post {
                always {
                    recordCoverage(
                        tools: [[parser: 'JACOCO', pattern: '**/target/site/jacoco/jacoco.xml']],
                        sourceCodeRetention: 'EVERY_BUILD'
                    )
                }
                failure {
                    echo "❌ Tests fallaron"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        echo "🔍 Ejecutando análisis de SonarQube..."
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.token=${SONAR_TOKEN} \
                                -Dsonar.projectKey=nordin-microservices-v2 \
                                -B
                        """
                    }
                }
            }
            post {
                always {
                    script {
                        try {
                            def qg = waitForQualityGate abortPipeline: false
                            echo "Quality Gate: ${qg.status}"
                        } catch (err) {
                            echo "⚠️ Quality Gate no disponible: ${err.message}"
                        }
                    }
                }
            }
        }

        stage('Build auth-service') {
            steps {
                sh "docker build -t auth-service:${IMAGE_TAG} -t auth-service:latest services/auth-service/"
            }
        }

        stage('Build organization-service') {
            steps {
                sh "docker build -t organization-service:${IMAGE_TAG} -t organization-service:latest services/organization-service/"
            }
        }

        stage('Build department-service') {
            steps {
                sh "docker build -t department-service:${IMAGE_TAG} -t department-service:latest services/department-service/"
            }
        }

        stage('Build employee-service') {
            steps {
                sh "docker build -t employee-service:${IMAGE_TAG} -t employee-service:latest services/employee-service/"
            }
        }

        stage('Build api-gateway') {
            steps {
                sh "docker build -t api-gateway:${IMAGE_TAG} -t api-gateway:latest infrastructure/api-gateway/"
            }
        }

        stage('Build admin-server') {
            steps {
                sh "docker build -t admin-server:${IMAGE_TAG} -t admin-server:latest infrastructure/admin-server/"
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline completado — Build: ${env.BUILD_NUMBER} — Tag: ${IMAGE_TAG}"
        }
        failure {
            echo "❌ Pipeline fallido — revisar logs"
        }
        always {
            sh "docker image prune -f || true"
        }
    }
}
