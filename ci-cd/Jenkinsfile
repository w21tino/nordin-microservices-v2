pipeline {

    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'JDK-21'
    }

    environment {
        AWS_REGION     = "${env.AWS_REGION ?: 'us-east-1'}"
        AWS_ACCOUNT_ID = "${env.AWS_ACCOUNT_ID ?: ''}"
        ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_TAG      = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'local'}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Compilar + Tests') {
            steps {
                echo "🔨 Compilando y ejecutando tests..."
                sh 'mvn clean verify -B'
            }
            post {
                always {
                    recordCoverage(
                        tools: [[parser: 'JACOCO', pattern: '**/target/site/jacoco/jacoco.xml']],
                        sourceCodeRetention: 'EVERY_BUILD'
                    )
                }
                failure {
                    echo "❌ Tests fallaron"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        echo "🔍 Ejecutando análisis de SonarQube..."
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.token=${SONAR_TOKEN} \
                                -Dsonar.projectKey=nordin-microservices-v2 \
                                -B
                        """
                    }
                }
            }
            post {
                always {
                    script {
                        try {
                            def qg = waitForQualityGate abortPipeline: false
                            echo "Quality Gate: ${qg.status}"
                        } catch (err) {
                            echo "⚠️ Quality Gate no disponible: ${err.message}"
                        }
                    }
                }
            }
        }

        stage('Build Imágenes Docker') {
            steps {
                script {
                    echo "🐳 Construyendo imágenes Docker..."
                    def buildJobs = [:]

                    ['auth-service', 'employee-service',
                     'department-service', 'organization-service'].each { svc ->
                        def s = svc
                        buildJobs[s] = {
                            sh "docker build -t ${s}:${IMAGE_TAG} -t ${s}:latest services/${s}/"
                            echo "  ✓ ${s}:${IMAGE_TAG}"
                        }
                    }

                    ['api-gateway', 'admin-server'].each { svc ->
                        def s = svc
                        buildJobs[s] = {
                            sh "docker build -t ${s}:${IMAGE_TAG} -t ${s}:latest infrastructure/${s}/"
                            echo "  ✓ ${s}:${IMAGE_TAG}"
                        }
                    }

                    parallel buildJobs
                }
            }
        }

        stage('Push a ECR') {
            when { branch 'main' }
            steps {
                script {
                    if (!env.AWS_ACCOUNT_ID) {
                        echo "⏭️ AWS_ACCOUNT_ID no configurado — saltando Push a ECR"
                        return
                    }
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        sh """
                            aws ecr get-login-password --region ${AWS_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        """
                        ['auth-service', 'employee-service', 'department-service',
                         'organization-service', 'api-gateway', 'admin-server'].each { svc ->
                            sh """
                                docker tag ${svc}:${IMAGE_TAG} ${ECR_REGISTRY}/nordin/${svc}:${IMAGE_TAG}
                                docker push ${ECR_REGISTRY}/nordin/${svc}:${IMAGE_TAG}
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo """
            ✅ Pipeline completado — Build: ${env.BUILD_NUMBER} — Tag: ${IMAGE_TAG}
            """
        }
        failure {
            echo "❌ Pipeline fallido — revisar logs"
        }
        always {
            sh "docker image prune -f || true"
        }
    }
}
